# Database-only environment settings.
# This file is loaded after .env and overrides DB-related values.

# Choose one: mysql or mongodb
DB_BACKEND=mysql

# MySQL settings (used when DB_BACKEND=mysql)
DB_HOST=localhost
DB_USER=inventory_app_user
DB_PASS=REPLACE_WITH_A_STRONG_PASSWORD
DB_NAME=inventory_db

# MongoDB settings (used when DB_BACKEND=mongodb)
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=inventory_db